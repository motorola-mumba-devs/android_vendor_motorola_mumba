cc_prebuilt_binary {
    name: "adpl",
    owner: "motorola",
    target: {
        android_arm64: {
            srcs: [
                "proprietary/vendor/bin/adpl",
            ],
            shared_libs: [
                "libc",
                "liblog",
                "libdiag",
                "libdsutils",
                "librmnetctl",
                "libqmi_cci",
                "libqmiservices",
                "libnetutils",
                "libcutils",
                "libqmi_client_qmux",
                "libqmi_encdec",
                "libqcmaputils",
                "libc++",
                "libm",
                "libdl",
            ],
        },
    },
    compile_multilib: "64",
    strip: {
        none: true,
    },
    prefer: true,
    soc_specific: true,
}


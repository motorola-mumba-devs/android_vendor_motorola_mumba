service vendor.camera-provider /vendor/bin/hw/vendor.qti.camera.provider-service_64
    interface aidl android.hardware.camera.provider.ICameraProvider/vendor_qti/0
    interface aidl vendor.qti.hardware.camera.postproc.IPostProcService/camerapostprocservice
    interface aidl com.motorola.hardware.camera.postprocess.IPostProcService/default
    interface vendor.qti.hardware.camera.aon@1.0::IAONService aoncameraservice
    class hal
    user cameraserver
    group audio camera input drmrpc oem_2907
    ioprio rt 4
    capabilities SYS_NICE
    task_profiles CameraServiceCapacity HighPerformance ProcessCapacityHigh
    writepid /dev/cpuset/camera-daemon/tasks

on boot
    chown cameraserver camera /sys/module/camera/parameters/cam_error_inject

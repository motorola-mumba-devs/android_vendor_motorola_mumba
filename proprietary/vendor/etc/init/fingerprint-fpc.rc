service vendor.fingerprint-fpc /vendor/bin/hw/android.hardware.biometrics.fingerprint-service.fpc
    #interface aidl android.hardware.biometrics.fingerprint.IFingerprint/default
    # "class hal" causes a race condition on some devices due to files created
    # in /data. As a workaround, postpone startup until later in boot once
    # /data is mounted.
    class late_start
    user system
    group system input uhid reserved_disk
    disabled
